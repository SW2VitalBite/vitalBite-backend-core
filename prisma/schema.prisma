generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  DISABLED
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum PatientStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum Gender {
  MALE
  FEMALE
  OTHER
  NOT_SPECIFIED
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  RESCHEDULED
  NO_SHOW
}

enum AppointmentMode {
  IN_PERSON
  VIRTUAL
}

enum MealType {
  DESAYUNO
  ALMUERZO
  CENA
  MERIENDA
}

enum NotificationType {
  CITA_CREADA
  CITA_CANCELADA
  CITA_CONFIRMADA
  CITA_REPROGRAMADA
  DIETA_ASIGNADA
  MENSAJE
  REPORTE
}

model Tenant {
  id               String            @id @default(uuid())
  name             String
  slug             String            @unique
  status           TenantStatus      @default(ACTIVE)
  users            User[]
  patients         Patient[]
  appointments     Appointment[]
  bodyMeasurements BodyMeasurement[]
  bodyCompositions BodyComposition[]
  diets            Diet[]
  notifications    Notification[]
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  deletedAt        DateTime?         @map("deleted_at")

  @@map("tenants")
}

model User {
  id                         String            @id @default(uuid())
  tenantId                   String            @map("tenant_id")
  email                      String
  passwordHash               String            @map("password_hash")
  firstName                  String            @map("first_name")
  lastName                   String            @map("last_name")
  status                     UserStatus        @default(ACTIVE)
  roleCode                   String            @map("role_code")
  tenant                     Tenant            @relation(fields: [tenantId], references: [id])
  assignedPatients           Patient[]         @relation("NutritionistPatients")
  nutritionistAppointments   Appointment[]     @relation("NutritionistAppointments")
  registeredBodyMeasurements BodyMeasurement[] @relation("RegisteredBodyMeasurements")
  nutritionistDiets          Diet[]            @relation("NutritionistDiets")
  createdAt                  DateTime          @default(now()) @map("created_at")
  updatedAt                  DateTime          @updatedAt @map("updated_at")
  deletedAt                  DateTime?         @map("deleted_at")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("users")
}

model Patient {
  id               String            @id @default(uuid())
  tenantId         String            @map("tenant_id")
  nutritionistId   String            @map("nutritionist_id")
  firstName        String            @map("first_name")
  lastName         String            @map("last_name")
  email            String?
  passwordHash     String?           @map("password_hash")
  phone            String?
  birthDate        DateTime?         @map("birth_date")
  gender           Gender?
  status           PatientStatus     @default(ACTIVE)
  clinicalNotes    String?           @map("clinical_notes")
  nutritionGoal    String?           @map("nutrition_goal")
  heightCm         Float?            @map("height_cm")
  expoPushToken    String?           @map("expo_push_token")
  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  nutritionist     User              @relation("NutritionistPatients", fields: [nutritionistId], references: [id])
  appointments     Appointment[]
  bodyMeasurements BodyMeasurement[]
  bodyCompositions BodyComposition[]
  diets            Diet[]
  notifications    Notification[]
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  deletedAt        DateTime?         @map("deleted_at")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, nutritionistId])
  @@index([tenantId, status])
  @@index([tenantId, lastName])
  @@map("patients")
}

model Appointment {
  id              String            @id @default(uuid())
  tenantId        String            @map("tenant_id")
  patientId       String            @map("patient_id")
  nutritionistId  String            @map("nutritionist_id")
  scheduledAt     DateTime          @map("scheduled_at")
  durationMinutes Int               @map("duration_minutes")
  status          AppointmentStatus @default(SCHEDULED)
  mode            AppointmentMode   @default(IN_PERSON)
  reason          String?
  notes           String?
  cancelReason    String?           @map("cancel_reason")
  tenant          Tenant            @relation(fields: [tenantId], references: [id])
  patient         Patient           @relation(fields: [patientId], references: [id])
  nutritionist    User              @relation("NutritionistAppointments", fields: [nutritionistId], references: [id])
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  deletedAt       DateTime?         @map("deleted_at")

  @@unique([tenantId, patientId, scheduledAt])
  @@index([tenantId, scheduledAt])
  @@index([tenantId, nutritionistId, scheduledAt])
  @@index([tenantId, patientId, scheduledAt])
  @@index([tenantId, status])
  @@map("appointments")
}

model BodyMeasurement {
  id               String            @id @default(uuid())
  tenantId         String            @map("tenant_id")
  patientId        String            @map("patient_id")
  registeredById   String            @map("registered_by_id")
  measuredAt       DateTime          @map("measured_at")
  weightKg         Float             @map("weight_kg")
  heightCm         Float?            @map("height_cm")
  bmi              Float?
  waistCm          Float?            @map("waist_cm")
  hipCm            Float?            @map("hip_cm")
  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  patient          Patient           @relation(fields: [patientId], references: [id])
  registeredBy     User              @relation("RegisteredBodyMeasurements", fields: [registeredById], references: [id])
  bodyCompositions BodyComposition[]
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  deletedAt        DateTime?         @map("deleted_at")

  @@unique([tenantId, patientId, measuredAt])
  @@index([tenantId, patientId, measuredAt])
  @@index([tenantId, registeredById])
  @@map("body_measurements")
}

model BodyComposition {
  id                String           @id @default(uuid())
  tenantId          String           @map("tenant_id")
  patientId         String           @map("patient_id")
  bodyMeasurementId String?          @map("body_measurement_id")
  measuredAt        DateTime         @map("measured_at")
  bodyFatPercentage Float?           @map("body_fat_percentage")
  muscleMassKg      Float?           @map("muscle_mass_kg")
  waterPercentage   Float?           @map("water_percentage")
  visceralFatLevel  Float?           @map("visceral_fat_level")
  boneMassKg        Float?           @map("bone_mass_kg")
  metabolicAge      Int?             @map("metabolic_age")
  tenant            Tenant           @relation(fields: [tenantId], references: [id])
  patient           Patient          @relation(fields: [patientId], references: [id])
  bodyMeasurement   BodyMeasurement? @relation(fields: [bodyMeasurementId], references: [id])
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  deletedAt         DateTime?        @map("deleted_at")

  @@unique([tenantId, patientId, measuredAt])
  @@index([tenantId, patientId, measuredAt])
  @@index([bodyMeasurementId])
  @@map("body_compositions")
}

model Diet {
  id             String     @id @default(uuid())
  tenantId       String     @map("tenant_id")
  patientId      String     @map("patient_id")
  nutritionistId String     @map("nutritionist_id")
  appointmentId  String?    @map("appointment_id")
  name           String
  objective      String?
  startDate      DateTime   @map("start_date")
  endDate        DateTime?  @map("end_date")
  isActive       Boolean    @default(true) @map("is_active")
  pdfUrl         String?    @map("pdf_url")
  tenant         Tenant     @relation(fields: [tenantId], references: [id])
  patient        Patient    @relation(fields: [patientId], references: [id])
  nutritionist   User       @relation("NutritionistDiets", fields: [nutritionistId], references: [id])
  meals          DietMeal[]
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  deletedAt      DateTime?  @map("deleted_at")

  @@index([tenantId, patientId])
  @@index([tenantId, patientId, isActive])
  @@map("diets")
}

model DietMeal {
  id       String     @id @default(uuid())
  dietId   String     @map("diet_id")
  mealType MealType   @map("meal_type")
  name     String?
  diet     Diet       @relation(fields: [dietId], references: [id])
  items    DietItem[]

  @@map("diet_meals")
}

model DietItem {
  id       String   @id @default(uuid())
  mealId   String   @map("meal_id")
  name     String
  quantity Float
  unit     String
  calories Float?
  protein  Float?
  carbs    Float?
  fat      Float?
  meal     DietMeal @relation(fields: [mealId], references: [id])

  @@map("diet_items")
}

model Notification {
  id        String           @id @default(uuid())
  tenantId  String           @map("tenant_id")
  patientId String           @map("patient_id")
  type      NotificationType
  title     String
  body      String
  data      Json?
  isRead    Boolean          @default(false) @map("is_read")
  tenant    Tenant           @relation(fields: [tenantId], references: [id])
  patient   Patient          @relation(fields: [patientId], references: [id])
  createdAt DateTime         @default(now()) @map("created_at")

  @@index([tenantId, patientId, isRead])
  @@index([tenantId, patientId, createdAt])
  @@map("notifications")
}
