generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  DISABLED
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum PatientStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum Gender {
  MALE
  FEMALE
  OTHER
  NOT_SPECIFIED
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  RESCHEDULED
  NO_SHOW
}

enum AppointmentMode {
  IN_PERSON
  VIRTUAL
}

enum DietPlanStatus {
  ACTIVE
  DRAFT
  NEEDS_ADJUSTMENT
}

model Tenant {
  id               String            @id @default(uuid())
  name             String
  slug             String            @unique
  status           TenantStatus      @default(ACTIVE)
  users            User[]
  patients         Patient[]
  appointments     Appointment[]
  bodyMeasurements BodyMeasurement[]
  bodyCompositions BodyComposition[]
  anthropometryMeasurements AnthropometryMeasurement[]
  dietPlans        DietPlan[]
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  deletedAt        DateTime?         @map("deleted_at")

  @@map("tenants")
}

model AuditEvent {
  id            String   @id @default(uuid())
  tenantId      String?  @map("tenant_id")
  tenantName    String?  @map("tenant_name")
  tenantSlug    String?  @map("tenant_slug")
  actorUserId   String?  @map("actor_user_id")
  actorTenantId String?  @map("actor_tenant_id")
  actorEmail    String?  @map("actor_email")
  actorRoleCode String?  @map("actor_role_code")
  action        String
  resourceType  String   @map("resource_type")
  resourceId    String?  @map("resource_id")
  summary       String
  metadata      Json?
  previousHash  String?  @map("previous_hash")
  eventHash     String   @map("event_hash")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@index([action, createdAt])
  @@index([resourceType, resourceId])
  @@index([actorUserId, createdAt])
  @@map("audit_events")
}

model User {
  id                         String            @id @default(uuid())
  tenantId                   String            @map("tenant_id")
  email                      String
  passwordHash               String            @map("password_hash")
  firstName                  String            @map("first_name")
  lastName                   String            @map("last_name")
  status                     UserStatus        @default(ACTIVE)
  roleCode                   String            @map("role_code")
  tenant                     Tenant            @relation(fields: [tenantId], references: [id])
  assignedPatients           Patient[]         @relation("NutritionistPatients")
  nutritionistAppointments   Appointment[]     @relation("NutritionistAppointments")
  registeredBodyMeasurements BodyMeasurement[] @relation("RegisteredBodyMeasurements")
  dietPlans                  DietPlan[]        @relation("NutritionistDietPlans")
  createdAt                  DateTime          @default(now()) @map("created_at")
  updatedAt                  DateTime          @updatedAt @map("updated_at")
  deletedAt                  DateTime?         @map("deleted_at")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("users")
}

model Patient {
  id               String            @id @default(uuid())
  tenantId         String            @map("tenant_id")
  nutritionistId   String            @map("nutritionist_id")
  firstName        String            @map("first_name")
  lastName         String            @map("last_name")
  email            String?
  phone            String?
  birthDate        DateTime?         @map("birth_date")
  gender           Gender?
  status           PatientStatus     @default(ACTIVE)
  clinicalNotes    String?           @map("clinical_notes")
  nutritionGoal    String?           @map("nutrition_goal")
  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  nutritionist     User              @relation("NutritionistPatients", fields: [nutritionistId], references: [id])
  appointments     Appointment[]
  bodyMeasurements BodyMeasurement[]
  bodyCompositions BodyComposition[]
  anthropometryMeasurements AnthropometryMeasurement[]
  dietPlans        DietPlan[]
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  deletedAt        DateTime?         @map("deleted_at")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, nutritionistId])
  @@index([tenantId, status])
  @@index([tenantId, lastName])
  @@map("patients")
}

model Appointment {
  id              String            @id @default(uuid())
  tenantId        String            @map("tenant_id")
  patientId       String            @map("patient_id")
  nutritionistId  String            @map("nutritionist_id")
  scheduledAt     DateTime          @map("scheduled_at")
  durationMinutes Int               @map("duration_minutes")
  status          AppointmentStatus @default(SCHEDULED)
  mode            AppointmentMode   @default(IN_PERSON)
  reason          String?
  notes           String?
  cancelReason    String?           @map("cancel_reason")
  tenant          Tenant            @relation(fields: [tenantId], references: [id])
  patient         Patient           @relation(fields: [patientId], references: [id])
  nutritionist    User              @relation("NutritionistAppointments", fields: [nutritionistId], references: [id])
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  deletedAt       DateTime?         @map("deleted_at")

  @@unique([tenantId, patientId, scheduledAt])
  @@index([tenantId, scheduledAt])
  @@index([tenantId, nutritionistId, scheduledAt])
  @@index([tenantId, patientId, scheduledAt])
  @@index([tenantId, status])
  @@map("appointments")
}

model BodyMeasurement {
  id               String            @id @default(uuid())
  tenantId         String            @map("tenant_id")
  patientId        String            @map("patient_id")
  registeredById   String            @map("registered_by_id")
  measuredAt       DateTime          @map("measured_at")
  weightKg         Float             @map("weight_kg")
  heightCm         Float?            @map("height_cm")
  bmi              Float?
  waistCm          Float?            @map("waist_cm")
  hipCm            Float?            @map("hip_cm")
  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  patient          Patient           @relation(fields: [patientId], references: [id])
  registeredBy     User              @relation("RegisteredBodyMeasurements", fields: [registeredById], references: [id])
  bodyCompositions BodyComposition[]
  anthropometryMeasurements AnthropometryMeasurement[]
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  deletedAt        DateTime?         @map("deleted_at")

  @@unique([tenantId, patientId, measuredAt])
  @@index([tenantId, patientId, measuredAt])
  @@index([tenantId, registeredById])
  @@map("body_measurements")
}

model BodyComposition {
  id                String           @id @default(uuid())
  tenantId          String           @map("tenant_id")
  patientId         String           @map("patient_id")
  bodyMeasurementId String?          @map("body_measurement_id")
  measuredAt        DateTime         @map("measured_at")
  bodyFatPercentage Float?           @map("body_fat_percentage")
  muscleMassKg      Float?           @map("muscle_mass_kg")
  waterPercentage   Float?           @map("water_percentage")
  visceralFatLevel  Float?           @map("visceral_fat_level")
  boneMassKg        Float?           @map("bone_mass_kg")
  metabolicAge      Int?             @map("metabolic_age")
  tenant            Tenant           @relation(fields: [tenantId], references: [id])
  patient           Patient          @relation(fields: [patientId], references: [id])
  bodyMeasurement   BodyMeasurement? @relation(fields: [bodyMeasurementId], references: [id])
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  deletedAt         DateTime?        @map("deleted_at")

  @@unique([tenantId, patientId, measuredAt])
  @@index([tenantId, patientId, measuredAt])
  @@index([bodyMeasurementId])
  @@map("body_compositions")
}

model AnthropometryMeasurement {
  id               String           @id @default(uuid())
  tenantId         String           @map("tenant_id")
  patientId        String           @map("patient_id")
  bodyMeasurementId String?         @map("body_measurement_id")
  measuredAt       DateTime         @map("measured_at")
  neckCm           Float?           @map("neck_cm")
  chestThoraxCm    Float?           @map("chest_thorax_cm")
  rightArmCm       Float?           @map("right_arm_cm")
  leftArmCm        Float?           @map("left_arm_cm")
  rightForearmCm   Float?           @map("right_forearm_cm")
  leftForearmCm    Float?           @map("left_forearm_cm")
  waistCm          Float?           @map("waist_cm")
  abdomenCm        Float?           @map("abdomen_cm")
  hipCm            Float?           @map("hip_cm")
  rightThighCm     Float?           @map("right_thigh_cm")
  leftThighCm      Float?           @map("left_thigh_cm")
  rightCalfCm      Float?           @map("right_calf_cm")
  leftCalfCm       Float?           @map("left_calf_cm")
  tenant           Tenant           @relation(fields: [tenantId], references: [id])
  patient          Patient          @relation(fields: [patientId], references: [id])
  bodyMeasurement  BodyMeasurement? @relation(fields: [bodyMeasurementId], references: [id])
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  deletedAt        DateTime?        @map("deleted_at")

  @@index([tenantId, patientId, measuredAt])
  @@index([bodyMeasurementId])
  @@map("anthropometry_measurements")
}

model DietPlan {
  id                String           @id @default(uuid())
  tenantId          String           @map("tenant_id")
  patientId         String           @map("patient_id")
  nutritionistId    String           @map("nutritionist_id")
  name              String
  objective         String
  phase             String?
  approach          String?
  startDate         DateTime?        @map("start_date")
  endDate           DateTime?        @map("end_date")
  status            DietPlanStatus   @default(DRAFT)
  mealsPerDay       Int?             @map("meals_per_day")
  mainRestriction   String?          @map("main_restriction")
  notes             String?
  estimatedCalories Int?             @map("estimated_calories")
  adherencePercent  Int?             @map("adherence_percent")
  tenant            Tenant           @relation(fields: [tenantId], references: [id])
  patient           Patient          @relation(fields: [patientId], references: [id])
  nutritionist      User             @relation("NutritionistDietPlans", fields: [nutritionistId], references: [id])
  days              DietPlanDay[]
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  deletedAt         DateTime?        @map("deleted_at")

  @@index([tenantId, patientId, status])
  @@index([tenantId, nutritionistId])
  @@index([tenantId, status])
  @@map("diet_plans")
}

model DietPlanDay {
  id         String     @id @default(uuid())
  dietPlanId String     @map("diet_plan_id")
  dayLabel   String     @map("day_label")
  dayOrder   Int        @map("day_order")
  dietPlan   DietPlan   @relation(fields: [dietPlanId], references: [id], onDelete: Cascade)
  meals      DietMeal[]
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  @@unique([dietPlanId, dayOrder])
  @@map("diet_plan_days")
}

model DietMeal {
  id             String         @id @default(uuid())
  dietPlanDayId  String         @map("diet_plan_day_id")
  name           String
  mealOrder      Int            @map("meal_order")
  targetCalories Int?           @map("target_calories")
  notes          String?
  day            DietPlanDay    @relation(fields: [dietPlanDayId], references: [id], onDelete: Cascade)
  items          DietMealItem[]
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  @@unique([dietPlanDayId, mealOrder])
  @@map("diet_meals")
}

model DietMealItem {
  id          String   @id @default(uuid())
  dietMealId  String   @map("diet_meal_id")
  name        String
  portion     String?
  calories    Int?
  itemOrder   Int      @map("item_order")
  notes       String?
  meal        DietMeal @relation(fields: [dietMealId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([dietMealId, itemOrder])
  @@map("diet_meal_items")
}
