NODE_ENV=development
PORT=3000
# Habilita GraphiQL en http://localhost:3000/graphql (reemplaza al Playground antiguo)
GRAPHQL_PLAYGROUND=true
GRAPHQL_LOG_RESPONSES=true
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vitalbite_core
JWT_SECRET=change-me-in-development
JWT_EXPIRES_IN=8h
PAYMENTS_SERVICE_URL=http://localhost:5100
# Microservicio de IA / ML (FastAPI)
AI_SERVICE_URL=http://localhost:8001
AI_API_KEY=vitalbite_ia_secret_key_dev_change_in_prod
# Microservicio documental (Spring Boot) — context-path /api/v1
DOCUMENTAL_SERVICE_URL=http://localhost:8082/api/v1
# Base del microservicio documental usada por diets.service (sin context-path)
DOCUMENTS_SERVICE_URL=http://localhost:8082
